{
  "manifest_version": 3,
  "name": "LinkedIn Job Tracker",
  "version": "1.3",
  "description": "Track LinkedIn jobs and export to jobs.xlsx for the resume pipeline",
  "permissions": ["storage", "downloads", "tabs", "notifications", "sidePanel"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://openrouter.ai/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://linkedin.com/jobs/*",
        "https://www.linkedin.com/jobs-tracker/*",
        "https://linkedin.com/jobs-tracker/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "LinkedIn Job Tracker",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png" }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [{"resources": ["pdf.worker.min.js"], "matches": ["<all_urls>"]}]
}
